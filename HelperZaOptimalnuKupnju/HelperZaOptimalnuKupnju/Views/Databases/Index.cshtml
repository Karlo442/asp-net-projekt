@model HelperZaOptimalnuKupnju.Models.DatabaseViewModel
@{
    ViewData["Title"] = "Baze Podataka";
}

<h1>Baze Podataka</h1>

<section>
    <h2>Informacije o bazi</h2>
    <ul>
        <li><strong>Putanja baze:</strong> @Model.DbPath</li>
        <li><strong>Users:</strong> @Model.Users</li>
        <li><strong>Stores:</strong> @Model.Stores</li>
        <li><strong>Products:</strong> @Model.Products</li>
        <li><strong>Orders:</strong> @Model.Orders</li>
        <li><strong>OrderItems:</strong> @Model.OrderItems</li>
    </ul>
    <p>
        <a class="btn btn-primary" href="/baze/download">Preuzmi SQLite datoteku</a>
    </p>
</section>

<section>
    <h2>ER Dijagram (Mermaid)</h2>
    <p>Renderiran koristeći Mermaid.js; ispod možeš generirati PNG za preuzimanje.</p>

    <div class="mermaid">
erDiagram
    USER {
        int Id PK
        string FirstName
        string LastName
        string Email
        string Phone
        DateTime RegisteredAt
        bool IsActive
        enum Role
    }
    ORDER {
        int Id PK
        int BuyerId FK
        DateTime CreatedAt
        DateTime ExpectedDeliveryDateTime
        enum Status
        decimal TotalAmount
    }
    ORDERITEM {
        int Id PK
        int OrderId FK
        int ProductId FK
        int Quantity
        decimal UnitPrice
    }
    PRODUCT {
        int Id PK
        string Name
        string Description
        decimal UnitPrice
    }
    STORE {
        int Id PK
        string Name
        string Brand
        string Address
        string City
        string Country
        string OpeningHours
    }

    USER ||--o{ ORDER : has
    ORDER ||--o{ ORDERITEM : contains
    PRODUCT ||--o{ ORDERITEM : included_in
    STORE }o--o{ PRODUCT : offers
    </div>

    <p class="mt-3">
        <button id="exportBtn" class="btn btn-secondary">Generiraj PNG</button>
    </p>

    <div class="mt-3">
        <h3>PNG Preview</h3>
        <img id="pngPreview" alt="ER diagram PNG preview" style="max-width:100%;border:1px solid #ddd;" />
        <p><a id="downloadPng" class="btn btn-success" download="er-diagram.png">Preuzmi PNG</a></p>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
    <script>
        mermaid.initialize({ startOnLoad: true });

        function svgToPng() {
            const svg = document.querySelector('.mermaid svg');
            if (!svg) {
                alert('SVG nije pronađen. Pričekaj da Mermaid renderira dijagram.');
                return;
            }
            const serializer = new XMLSerializer();
            const svgString = serializer.serializeToString(svg);
            const svgBlob = new Blob([svgString], { type: 'image/svg+xml;charset=utf-8' });
            const url = URL.createObjectURL(svgBlob);
            const img = new Image();
            img.onload = function () {
                const canvas = document.createElement('canvas');
                canvas.width = img.width;
                canvas.height = img.height;
                const ctx = canvas.getContext('2d');
                ctx.fillStyle = 'white';
                ctx.fillRect(0, 0, canvas.width, canvas.height);
                ctx.drawImage(img, 0, 0);
                const png = canvas.toDataURL('image/png');
                const preview = document.getElementById('pngPreview');
                preview.src = png;
                const download = document.getElementById('downloadPng');
                download.href = png;
                URL.revokeObjectURL(url);
            };
            img.onerror = function () {
                alert('Greška pri konverziji SVG -> PNG');
                URL.revokeObjectURL(url);
            };
            img.src = url;
        }

        document.getElementById('exportBtn').addEventListener('click', svgToPng);
    </script>
}
