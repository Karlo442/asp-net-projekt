@model IEnumerable<HelperZaOptimalnuKupnju.Models.OrderItem>
@{
    ViewData["Title"] = "Order Items";
}
<div class="page-header">
    <div>
        <p class="eyebrow">Entity list</p>
        <h1>Order Items</h1>
    </div>
    <nav class="breadcrumb">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <span>Order Items</span>
    </nav>
</div>
<div class="entity-card">
    <table class="entity-table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Product</th>
                <th>Order</th>
                <th>Quantity</th>
                <th>Unit Price</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td><a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId">@item.Product.Name</a></td>
                    <td><a asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId">Order #@item.OrderId</a></td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitPrice:C</td>
                    <td><a asp-action="Details" asp-route-id="@item.Id">Details</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>
