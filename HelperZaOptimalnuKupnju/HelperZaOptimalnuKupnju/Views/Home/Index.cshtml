@{
    ViewData["Title"] = "Mock Repository Home";
    var counts = ViewBag.EntityCounts as Dictionary<string, int>;
}
<div class="page-hero hero-large">
    <div class="hero-copy">
        <span class="eyebrow">Mock repository demo</span>
        <h1>Static data, clean navigation, and entity details</h1>
        <p>Explore the mock repository for stores, users, products, orders, and order items. Each entity includes an index list and a details page.</p>
        <div class="hero-actions">
            <a class="btn btn-primary" asp-controller="Users" asp-action="Index">View Users</a>
            <a class="btn btn-secondary" asp-controller="Stores" asp-action="Index">View Stores</a>
        </div>
    </div>
</div>

<section class="summary-grid">
    @if (counts != null)
    {
        foreach (var kv in counts)
        {
            <article class="summary-card">
                <h2>@kv.Value</h2>
                <p>@kv.Key</p>
            </article>
        }
    }
</section>

<section class="content-section">
    <div class="section-card">
        <h2>How to navigate</h2>
        <p>Use the navigation menu to visit all entity pages. Each index page links to details.</p>
    </div>
</section>

<!-- Discount Pop-up Modal -->
<div class="discount-modal-overlay" id="discountModalOverlay">
    <div class="discount-modal" id="discountModal">
        <button class="modal-close" id="closeDiscountModal">×</button>
        
        <div class="modal-content">
            <div class="discount-header">
                <span class="flash-text">FLASH DEAL</span>
            </div>
            
            <div class="discount-badge">
                <span class="discount-percent">50%</span>
                <span class="discount-label">OFF</span>
            </div>
            
            <h2 class="modal-title">Special Offer Just For You!</h2>
            <p class="modal-subtitle">Limited time discount on your next order</p>
            
            <div class="promo-code-box">
                <input type="text" class="promo-input" value="LUCKY50" readonly>
                <button class="copy-btn" id="copyPromoBtn">Copy Code</button>
            </div>
            
            <p class="offer-terms">Valid until end of month • Applies to orders over 100 kn</p>
            
            <button class="btn-claim" id="claimOfferBtn">Claim Offer</button>
        </div>
        
        <!-- Particle effects -->
        <div class="particle" id="particle1"></div>
        <div class="particle" id="particle2"></div>
        <div class="particle" id="particle3"></div>
        <div class="particle" id="particle4"></div>
        <div class="particle" id="particle5"></div>
    </div>
</div>

