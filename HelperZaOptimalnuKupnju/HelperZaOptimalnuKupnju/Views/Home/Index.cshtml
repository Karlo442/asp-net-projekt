@{
    ViewData["Title"] = "Mock Repository Home";
    var counts = ViewBag.EntityCounts as Dictionary<string, int>;
}
<div class="page-hero hero-large">
    <div class="hero-copy">
        <span class="eyebrow">Mock repository demo</span>
        <h1>Static data, clean navigation, and entity details</h1>
        <p>Explore the mock repository for stores, users, products, orders, and order items. Each entity includes an index list and a details page.</p>
        <div class="hero-actions">
            <a class="btn btn-primary" asp-controller="Users" asp-action="Index">View Users</a>
            <a class="btn btn-secondary" asp-controller="Stores" asp-action="Index">View Stores</a>
        </div>
    </div>
</div>

<section class="summary-grid">
    @if (counts != null)
    {
        foreach (var kv in counts)
        {
            <article class="summary-card">
                <h2>@kv.Value</h2>
                <p>@kv.Key</p>
            </article>
        }
    }
</section>

<section class="content-section">
    <div class="section-card">
        <h2>How to navigate</h2>
        <p>Use the navigation menu to visit all entity pages. Each index page links to details.</p>
    </div>
</section>

<!-- Discount Pop-up Modal -->
<div class="discount-modal-overlay" id="discountModalOverlay">
    <div class="discount-modal" id="discountModal">
        <button class="modal-close" id="closeDiscountModal">×</button>
        
        <div class="modal-content">
            <div class="discount-header">
                <span class="flash-text">FLASH DEAL</span>
            </div>
            
            <div class="discount-badge">
                <span class="discount-percent">50%</span>
                <span class="discount-label">OFF</span>
            </div>
            
            <h2 class="modal-title">Special Offer Just For You!</h2>
            <p class="modal-subtitle">Limited time discount on your next order</p>
            
            <div class="promo-code-box">
                <input type="text" class="promo-input" value="LUCKY50" readonly>
                <button class="copy-btn" id="copyPromoBtn">Copy Code</button>
            </div>
            
            <p class="offer-terms">Valid until end of month • Applies to orders over 100€</p>
            
            <button class="btn-claim" id="claimOfferBtn">Claim Offer</button>
        </div>
        
        <!-- Particle effects -->
        <div class="particle" id="particle1"></div>
        <div class="particle" id="particle2"></div>
        <div class="particle" id="particle3"></div>
        <div class="particle" id="particle4"></div>
        <div class="particle" id="particle5"></div>
    </div>
</div>

<!-- Complaints Section -->
@if (User.Identity?.IsAuthenticated == true)
{
    <section class="section-card complaints-section">
        <h2>Upload žalbe</h2>
        <p class="muted">Dodaj naslov, opis i datoteku žalbe.</p>
        
        <form class="dropzone complaint-dropzone" id="complaintForm" action="/api/complaints" method="POST" enctype="multipart/form-data">
            <div class="mb-3">
                <input type="text" name="title" class="form-control mb-2" placeholder="Naslov žalbe" required>
                <textarea name="description" class="form-control" rows="3" placeholder="Opis žalbe..." required></textarea>
            </div>
            <div class="dz-message needsclick">
                <span>Prevuci datoteku ovdje ili klikni za odabir</span>
            </div>
            <button type="button" id="submitComplaintBtn" class="btn btn-primary mt-3">Pošalji žalbu</button>
        </form>

        <div id="complaintStatus" class="mt-3"></div>

        <div id="complaintsContainer" class="mt-4">
            <h3>Uploadane žalbe</h3>
            <div id="complaintsList" class="complaints-list"></div>
        </div>
    </section>
}

@section Scripts {
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
        Dropzone.autoDiscover = false;

        const complaintForm = document.getElementById('complaintForm');
        const complaintStatus = document.getElementById('complaintStatus');

        const complaintDropzone = new Dropzone('#complaintForm', {
            url: '/api/complaints',
            paramName: "file",
            maxFilesize: 10,
            maxFiles: 1,
            acceptedFiles: ".pdf,.doc,.docx,.txt,.jpg,.jpeg,.png",
            autoProcessQueue: false,
            addRemoveLinks: true,
            dictRemoveFile: "Ukloni",
            dictDefaultMessage: "Prevuci datoteku ovdje ili klikni za odabir",
            init: function () {
                this.on("maxfilesexceeded", function (file) {
                    this.removeAllFiles();
                    this.addFile(file);
                });
            }
        });

        document.getElementById('submitComplaintBtn').addEventListener('click', function () {
            const title = complaintForm.querySelector('input[name="title"]').value.trim();
            const description = complaintForm.querySelector('textarea[name="description"]').value.trim();

            if (!title || !description) {
                showComplaintStatus('Popuni naslov i opis žalbe.', 'danger');
                return;
            }

            const queuedFiles = complaintDropzone.getQueuedFiles();
            submitComplaint(queuedFiles.length > 0 ? queuedFiles[0] : null, title, description);
        });

        function submitComplaint(file, title, description) {
            const formData = new FormData();
            formData.append('title', title);
            formData.append('description', description);
            if (file) {
                formData.append('file', file);
            }

            showComplaintStatus('Šaljem žalbu...', 'info');

            fetch('/api/complaints', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Upload nije uspio.');
                }
                return response.json();
            })
            .then(() => {
                showComplaintStatus('Žalba je uspješno uploadana.', 'success');
                complaintForm.reset();
                complaintDropzone.removeAllFiles(true);
                loadComplaints();
            })
            .catch(error => {
                console.error('Greška:', error);
                showComplaintStatus(error.message, 'danger');
            });
        }

        function loadComplaints() {
            fetch('/api/complaints')
            .then(response => {
                if (!response.ok) {
                    throw new Error('Popis žalbi nije moguće učitati.');
                }
                return response.json();
            })
            .then(data => {
                const container = document.getElementById('complaintsList');
                container.innerHTML = '';

                if (data.length === 0) {
                    container.innerHTML = '<p class="muted">Još nema uploadanih žalbi.</p>';
                    return;
                }

                data.forEach(complaint => {
                    const card = document.createElement('div');
                    card.className = 'complaint-card';

                    const body = document.createElement('div');
                    const title = document.createElement('h5');
                    const description = document.createElement('p');
                    const createdAt = document.createElement('small');
                    const file = document.createElement(complaint.filePath ? 'a' : 'span');
                    const deleteButton = document.createElement('button');

                    title.textContent = complaint.title;
                    description.textContent = complaint.description;
                    createdAt.textContent = `Uploadano: ${new Date(complaint.createdAt).toLocaleString('hr-HR')}`;

                    if (complaint.filePath) {
                        file.href = `/${complaint.filePath}`;
                        file.target = '_blank';
                        file.textContent = complaint.originalFileName || 'Preuzmi datoteku';
                    } else {
                        file.className = 'muted';
                        file.textContent = 'Bez datoteke';
                    }

                    deleteButton.type = 'button';
                    deleteButton.className = 'btn btn-sm btn-danger';
                    deleteButton.textContent = 'Obriši';
                    deleteButton.addEventListener('click', () => deleteComplaint(complaint.id));

                    body.append(title, description, createdAt, document.createElement('br'), file);
                    card.append(body, deleteButton);
                    container.appendChild(card);
                });
            })
            .catch(error => {
                console.error('Greška:', error);
                showComplaintStatus(error.message, 'danger');
            });
        }

        function deleteComplaint(id) {
            if (!confirm('Sigurno želiš obrisati ovu žalbu?')) return;

            fetch(`/api/complaints/${id}`, {
                method: 'DELETE'
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Brisanje nije uspjelo.');
                }
                showComplaintStatus('Žalba je obrisana.', 'success');
                loadComplaints();
            })
            .catch(error => {
                console.error('Greška:', error);
                showComplaintStatus(error.message, 'danger');
            });
        }

        function showComplaintStatus(message, type) {
            complaintStatus.innerHTML = `<div class="alert alert-${type}" role="alert">${message}</div>`;
        }

        document.addEventListener('DOMContentLoaded', loadComplaints);
        </script>
    }
}
