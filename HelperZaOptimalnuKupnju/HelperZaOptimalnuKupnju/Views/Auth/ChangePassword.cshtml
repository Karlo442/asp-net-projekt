@model ChangePasswordDTO

@{
    ViewData["Title"] = "Promjena lozinke";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body p-5">
                    <h1 class="h3 mb-4 text-center">Promjena lozinke</h1>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            @TempData["SuccessMessage"]
                        </div>
                    }

                    <form method="post" asp-action="ChangePassword">
                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Keys.Any())
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                <strong>Greške:</strong>
                                <ul class="mb-0">
                                    @foreach (var modelState in ViewData.ModelState.Values)
                                    {
                                        foreach (var error in modelState.Errors)
                                        {
                                            <li>@error.ErrorMessage</li>
                                        }
                                    }
                                </ul>
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="OldPassword" class="form-label">Stara lozinka</label>
                            <input asp-for="OldPassword" class="form-control" type="password" />
                            <span asp-validation-for="OldPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label">Nova lozinka</label>
                            <input asp-for="NewPassword" class="form-control" type="password" placeholder="Najmanje 6 znakova" />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label">Potvrdi novu lozinku</label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mb-3">Promijeni lozinku</button>
                    </form>

                    <p class="text-center mb-0">
                        <a asp-action="Profile">Nazad na profil</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
