@model LoginDTO

@{
    ViewData["Title"] = "Prijava";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-body p-5">
                    <h1 class="h3 mb-4 text-center">Prijava</h1>

                    <form method="post" asp-action="Login">
                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Keys.Any())
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                <strong>Greška:</strong>
                                <ul class="mb-0">
                                    @foreach (var modelState in ViewData.ModelState.Values)
                                    {
                                        foreach (var error in modelState.Errors)
                                        {
                                            <li>@error.ErrorMessage</li>
                                        }
                                    }
                                </ul>
                            </div>
                        }

                        <div class="mb-3">
                            <label asp-for="UserNameOrEmail" class="form-label">Korisničko ime ili Email</label>
                            <input asp-for="UserNameOrEmail" class="form-control" placeholder="Korisničko ime ili email" autofocus />
                            <span asp-validation-for="UserNameOrEmail" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Lozinka</label>
                            <input asp-for="Password" class="form-control" type="password" placeholder="Vaša lozinka" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                            <label asp-for="RememberMe" class="form-check-label">
                                Zapamti me
                            </label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mb-3">Prijava</button>
                    </form>

                    <p class="text-center mb-0">
                        Nemate račun? <a asp-action="Register">Registracija</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
