@model UserProfileDTO

@{
    ViewData["Title"] = "Moj profil";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0">Profil korisnika</h2>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h5>Osnovni podaci</h5>
                            <dl class="row">
                                <dt class="col-sm-4">Korisničko ime:</dt>
                                <dd class="col-sm-8">@Model.UserName</dd>

                                <dt class="col-sm-4">Ime:</dt>
                                <dd class="col-sm-8">@Model.FirstName @Model.LastName</dd>

                                <dt class="col-sm-4">Email:</dt>
                                <dd class="col-sm-8">@Model.Email</dd>

                                <dt class="col-sm-4">Telefon:</dt>
                                <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Nije upisano" : Model.PhoneNumber)</dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <h5>Adresni podaci</h5>
                            <dl class="row">
                                <dt class="col-sm-4">Adresa:</dt>
                                <dd class="col-sm-8">@Model.Address</dd>

                                <dt class="col-sm-4">Grad:</dt>
                                <dd class="col-sm-8">@Model.City</dd>

                                <dt class="col-sm-4">Poštanski broj:</dt>
                                <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.ZipCode) ? "Nije upisano" : Model.ZipCode)</dd>

                                <dt class="col-sm-4">Registriran:</dt>
                                <dd class="col-sm-8">@Model.CreatedAt.ToString("dd.MM.yyyy")</dd>
                            </dl>
                        </div>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-md-12">
                            <h5>Uloga</h5>
                            @if (Model.Roles.Any())
                            {
                                <div class="d-flex gap-2">
                                    @foreach (var role in Model.Roles)
                                    {
                                        <span class="badge bg-info">@role</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <p>Nema dodijeljene uloge</p>
                            }
                        </div>
                    </div>

                    <hr />

                    <div class="row">
                        <div class="col-md-12">
                            <div class="d-flex gap-2">
                                <a asp-action="ChangePassword" class="btn btn-warning">Promjena lozinke</a>
                                <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">Natrag na početnu</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
