@model HelperZaOptimalnuKupnju.Models.Order
@{
    ViewData["Title"] = "Order Details";
}
@Html.AntiForgeryToken()

<div class="page-header">
    <div>
        <p class="eyebrow">Details</p>
        <h1>Order #@Model.Id</h1>
    </div>
    <nav class="breadcrumb">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <a asp-controller="Orders" asp-action="Index">Orders</a>
        <span>Details</span>
    </nav>
</div>
<div class="detail-card">
    <div class="detail-grid">
        <div>
            <h3>Buyer</h3>
            <p>@Model.Buyer.FirstName @Model.Buyer.LastName</p>
            <p>@Model.Buyer.Email</p>
        </div>
        <div>
            <h3>Status</h3>
            <p>@Model.Status</p>
        </div>
        <div>
            <h3>Created</h3>
            <p>@Model.CreatedAt:yyyy-MM-dd</p>
        </div>
        <div>
            <h3>Expected delivery</h3>
            <p>@Model.ExpectedDeliveryDateTime:yyyy-MM-dd</p>
        </div>
        <div>
            <h3>Total</h3>
            <p><strong>@Model.TotalAmount:C</strong></p>
        </div>
    </div>
    @if (Model.Items != null && Model.Items.Any())
    {
        <section class="section-card">
            <h2>Items</h2>
            <ul class="detail-list">
                @foreach (var item in Model.Items)
                {
                    <li><a asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId">@item.Product.Name</a> — @item.Quantity × @item.UnitPrice:C</li>
                }
            </ul>
        </section>
    }
    <div class="action-buttons" style="margin-top: 20px; display: flex; gap: 10px;">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Uredi</a>
        <button class="btn btn-danger delete-btn-detail" data-id="@Model.Id">Obriši</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/celebration-animation.js"></script>
    <script>
        document.querySelector('.delete-btn-detail')?.addEventListener('click', function() {
            const orderId = this.dataset.id;
            if (confirm('Jeste li sigurni da želite obrisati ovu narudžbu?')) {
                deleteOrder(orderId);
            }
        });

        function deleteOrder(id) {
            fetch(`/narudz/obrisi/${id}`, {
                method: 'POST',
                headers: {
                    'X-CSRF-TOKEN': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                }
            })
            .then(response => {
                if (response.ok) {
                    alert('Narudžba je obrisana.');
                    window.location.href = '/narudz/lista';
                } else {
                    return response.text().then(text => {
                        alert('Greška pri brisanju: ' + text);
                    });
                }
            })
            .catch(err => {
                console.error('Greška:', err);
                alert('Greška pri brisanju: ' + err);
            });
        }
    </script>
}
