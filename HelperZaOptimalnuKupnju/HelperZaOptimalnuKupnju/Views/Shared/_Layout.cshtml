<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HelperZaOptimalnuKupnju</title>
    <script type="importmap"></script>
    @Html.AntiForgeryToken()
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HelperZaOptimalnuKupnju.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/dropzone.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">HelperZaOptimalnuKupnju</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/korisn/lista">Korisnici</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/trgov/sve">Trgovine</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/proizv/lista">Proizvodi</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/narudz/sve">Narudžbe</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/orderitems">Stavke</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/list-example">Primjer Liste</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/baze">Baze Podataka</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-dark">
                                    @User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Auth" asp-action="Profile">Profil</a>
                            </li>
                            <li class="nav-item">
                                <form method="post" asp-area="" asp-controller="Auth" asp-action="Logout" style="display: inline;">
                                    <button type="submit" class="btn btn-link nav-link text-dark" style="cursor: pointer; border: none; padding: 0;">Odjava</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Auth" asp-action="Login">Prijava</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Auth" asp-action="Register">Registracija</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/dropzone/5.9.3/dropzone.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
